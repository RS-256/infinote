{
	"schemaVersion": 1,
	"id": "infinote",
	"version": "${version}",
	"name": "infinote",
	"description": "the sky is the limit! noteblock should be configurable!",
	"authors": [
		"RS256"
	],
	"contact": {
		"sources": "https://github.com/RS-256/infinote"
	},
	"license": "MIT",
	"icon": "assets/infinote/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.rs256.infinote.Infinote"
		],
		"client": [
			"com.rs256.infinote.client.InfinoteClient"
		]
	},
	"mixins": [
		"infinote.mixins.json",
		{
			"config": "infinoteClient.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "${minecraft}",
		"java": ">=17",
		"${fabricApiKey}": "*"
